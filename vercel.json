{
  "builds": [
    {
      "src": "backend/backend/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "backend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/backend/wsgi.py"
    }
  ]
}
